# Traefik — variables de entorno
# Copia como .env y rellena los valores antes de ejecutar setup.sh

# Correo para notificaciones de Let's Encrypt
ACME_EMAIL=alertas@cloudcontrol.cl

# Dominio donde se expondrá el dashboard de Traefik
TRAEFIK_DOMAIN=traefik.cloudcontrol.cl

# Hash Basic Auth para el dashboard
# Generar: echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$cambiaestoporunhashreal
